{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["done", "question", "rationale", "confidence"],
  "properties": {
    "done": {
      "type": "boolean"
    },
    "question": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
