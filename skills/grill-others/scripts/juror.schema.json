{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stance",
    "recommendation",
    "rationale",
    "assumptions",
    "risks",
    "repo_findings",
    "questions_for_other_jurors",
    "confidence"
  ],
  "properties": {
    "stance": {
      "type": "string",
      "enum": ["recommend", "block", "needs-evidence"]
    },
    "recommendation": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "repo_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "questions_for_other_jurors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["to", "question", "why"],
        "properties": {
          "to": {
            "type": "string"
          },
          "question": {
            "type": "string"
          },
          "why": {
            "type": "string"
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
